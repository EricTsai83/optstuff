# App URL (used for API endpoints display)
NEXT_PUBLIC_APP_URL="http://localhost:3024"

# Documentation site URL
NEXT_PUBLIC_DOCS_URL="https://docs.example.com"

# API Key Encryption (32+ chars, generate with: openssl rand -base64 32)
API_KEY_ENCRYPTION_SECRET="your-32-character-secret-key-here-abc"

# Shared secret for authenticated cron routes (required in production)
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret"

# Success request log sampling rate (0.0 ~ 1.0). Errors are always logged.
# Recommended for production: 0.1 ~ 0.3
REQUEST_LOG_SUCCESS_SAMPLE_RATE="0.2"

# Drizzle
# Recommended for most uses
DATABASE_URL="postgresql://postgres:password@localhost:5432/your_database"

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED="postgresql://postgres:password@localhost:5432/your_database"

# Parameters for constructing your own connection string
PGHOST="your-host.neon.tech"
PGHOST_UNPOOLED="your-host-unpooled.neon.tech"
PGUSER="your_user"
PGDATABASE="your_database"
PGPASSWORD="your_password"

# Parameters for Vercel Postgres Templates
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database?sslmode=require"
POSTGRES_USER="your_user"
POSTGRES_HOST="your-host.neon.tech"
POSTGRES_PASSWORD="your_password"
POSTGRES_DATABASE="your_database"
POSTGRES_URL_NO_SSL="postgresql://user:password@host/database"
POSTGRES_PRISMA_URL="postgresql://user:password@host/database?connect_timeout=15&sslmode=require"
NEON_PROJECT_ID="your-neon-project-id"

# ======================================================
# Clerk
# ======================================================
# Server
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Client
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Debug mode for microfrontends
MFE_DEBUG="0"
